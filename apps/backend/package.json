{
  "name": "@wonderkamer/backend",
  "version": "1.6.0",
  "private": true,
  "description": "website voor Stichting Wonderkamer",
  "repository": "",
  "license": "UNLICENSED",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_ENV=development nest start",
    "start:dev": "NODE_ENV=development nest start --debug --watch --preserveWatchOutput",
    "start:debug": "NODE_ENV=development nest start --debug --watch --preserveWatchOutput",
    "start:docker": "node dist/main",
    "start:db": "ssh -N -L 54320:127.0.0.1:54320 root@s02.plhw.nl",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --passWithNoTests",
    "test:dev": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "letsencrypt": "nest build && node dist/lets-encrypt.js",
    "typeorm": "ts-node -r tsconfig-paths/register --project tsconfig.json ./node_modules/typeorm/cli",
    "typeorm:help": "pnpm run typeorm --version",
    "typeorm:migration:run": "pnpm run typeorm migration:run -d ./src/typeOrm.config.ts",
    "typeorm:migration:generate": "pnpm run typeorm migration:generate -d ./src/typeOrm.config.ts",
    "typeorm:migration:show": "pnpm run typeorm migration:show -d ./src/typeOrm.config.ts",
    "typeorm:migration:create": "pnpm run typeorm migration:create",
    "typeorm:migration:revert": "pnpm run typeorm migration:revert -d ./src/typeOrm.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.733.0",
    "@bull-board/api": "6.7.10",
    "@bull-board/express": "6.7.10",
    "@bull-board/nestjs": "6.7.10",
    "@bull-board/ui": "6.7.10",
    "@liaoliaots/nestjs-redis": "10.0.0",
    "@nestjs-modules/mailer": "2.0.2",
    "@nestjs/axios": "3.1.3",
    "@nestjs/bullmq": "10.2.3",
    "@nestjs/cache-manager": "2.3.0",
    "@nestjs/common": "11.0.12",
