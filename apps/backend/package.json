    "@nextnm/nestjs-mailgun": "3.0.1",
    "@stdlib/utils-convert-path": "0.2.2",
    "@wonderkamer/common": "workspace:*",
    "ajv": "8.17.1",
    "async": "3.2.6",
    "axios": "1.7.9",
    "bcrypt": "5.1.1",
    "body-parser": "1.20.3",
    "bullmq": "5.45.0",
