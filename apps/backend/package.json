{
  "name": "@wonderkamer/backend",
  "version": "1.10.0",
  "private": true,
  "description": "website voor Stichting Wonderkamer",
  "repository": "",
  "license": "UNLICENSED",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "nest build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "pnpm --filter @wonderkamer/email-templates build && EMBER_PROXY_TARGET=http://127.0.0.1:4222 NODE_ENV=development nest start",
    "start:dev": "pnpm --filter @wonderkamer/email-templates build && EMBER_PROXY_TARGET=http://127.0.0.1:4222 NODE_ENV=development nest start --debug --watch --preserveWatchOutput",
    "start:debug": "pnpm --filter @wonderkamer/email-templates build && EMBER_PROXY_TARGET=http://127.0.0.1:4222 NODE_ENV=development nest start --debug --watch --preserveWatchOutput",
    "start:docker": "node dist/main",
    "start:db": "ssh -N -L 54320:127.0.0.1:54320 root@s02.plhw.nl",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --passWithNoTests",
    "test:dev": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "letsencrypt": "nest build && node dist/lets-encrypt.js",
    "typeorm": "ts-node -r tsconfig-paths/register --project tsconfig.json ./node_modules/typeorm/cli",
    "typeorm:help": "pnpm run typeorm --version",
    "typeorm:migration:run": "pnpm run typeorm migration:run -d ./src/typeOrm.config.ts",
    "typeorm:migration:generate": "pnpm run typeorm migration:generate -d ./src/typeOrm.config.ts",
    "typeorm:migration:show": "pnpm run typeorm migration:show -d ./src/typeOrm.config.ts",
    "typeorm:migration:create": "pnpm run typeorm migration:create",
    "typeorm:migration:revert": "pnpm run typeorm migration:revert -d ./src/typeOrm.config.ts"
  },
  "dependencies": {
    "@bull-board/api": "6.9.6",
    "@bull-board/express": "6.9.6",
    "@bull-board/nestjs": "6.9.6",
    "@bull-board/ui": "6.9.6",
    "@nestjs-modules/mailer": "2.3.6",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.26",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.26",
    "@nestjs/platform-express": "11.1.26",
    "@nestlab/google-recaptcha": "3.11.2",
    "bullmq": "5.48.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.4",
    "dotenv": "16.6.1",
    "express": "5.1.0",
    "handlebars": "4.7.9",
    "ioredis": "5.6.1",
    "nestjs-ember-static": "0.3.1",
    "nodemailer": "8.0.10",
    "pg": "8.14.1",
    "redis": "4.7.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeorm": "0.3.30"
  },
  "devDependencies": {
    "@golevelup/ts-jest": "0.6.2",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.26",
    "@nullvoxpopuli/eslint-configs": "6.0.0",
    "@types/express": "5.0.6",
    "@types/jest": "29.5.14",
    "@types/node": "22.14.1",
    "@types/nodemailer": "6.4.17",
    "@types/supertest": "6.0.3",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "jest": "29.7.0",
    "prettier": "3.8.4",
    "supertest": "7.1.4",
    "ts-jest": "29.3.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.5.4",
    "typescript-eslint": "8.61.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "turbo": {
    "tasks": {
      "build": {
        "outputs": [
          "dist/**"
        ]
      }
    }
  }
}
