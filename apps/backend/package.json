    "cache-manager-redis-store": "3.0.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cron": "3.5.0",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "find-remove": "5.0.0",
    "form-data": "4.0.2",
    "handlebars": "4.7.8",
    "ini": "5.0.0",
    "ioredis": "5.4.2",
    "js-beautify": "1.15.4",
    "jsonapi-serializer": "3.6.9",
    "jsonwebtoken": "9.0.2",
    "ms": "2.1.3",
    "multi-ini": "2.3.2",
    "nestjs-ember-static": "0.2.4",
    "nestjs-s3": "2.1.0-next.1",
    "node-fetch-commonjs": "3.3.2",
    "node-html-parser": "7.0.1",
    "nodemailer": "6.10.0",
    "object-hash": "3.0.0",
    "passport": "0.7.0",
    "passport-custom": "1.1.1",
    "passport-http": "0.3.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pg": "8.14.1",
    "prom-client": "15.1.3",
    "redis": "4.7.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "semver": "7.7.1",
