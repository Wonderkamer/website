<div class="container mx-auto align-self-center px-4" ...attributes>
  <div>
    <h2 class="text-3xl py-5">Contact</h2>
  </div>

  <div class="grid grid-cols-12 gap-4">
    <div class="prose col-span-12 md:col-span-5">
      <Util::MarkdownFromUrl @url="/sections/contact.md" />
    </div>
    <div class="col-span-12 md:col-span-7">

      {{#if this.isSubmitted}}
        <p>Bedankt voor je reactie, we nemen contact met je op...</p>
      {{/if}}

      {{#unless this.isSubmitted}}

        <HeadlessForm @data={{this.changeset}} @dataMode="mutable" @onSubmit={{this.onSubmit}} @validate={{(validate-changeset)}} autocomplete="off" as |form|>
          <form.Field @name="name" as |field|>
            <field.Label class="form-control flex flex-col items-start w-full max-w-md mb-4">
              <div class="label justify-start pb-1">
                <span class="label-text">Naam</span>
              </div>
              <field.Input class="input input-bordered w-full focus:outline-none focus:ring-2 focus:ring-[#ffe607] focus:border-[#ffe607]" />
              <field.Errors class="w-full pt-1 text-right" as |errors|>
                <span class="label-text-alt block w-full text-xs text-orange-600 text-right">{{get (get errors 0) "message"}}</span>
              </field.Errors>
            </field.Label>

          </form.Field>

          <form.Field @name="email" as |field|>
            <field.Label class="form-control flex flex-col items-start w-full max-w-md mb-4">
              <div class="label justify-start pb-1">
                <span class="label-text">E-mail</span>
              </div>
              <field.Input @type="email" class="input input-bordered w-full focus:outline-none focus:ring-2 focus:ring-[#ffe607] focus:border-[#ffe607]" />
              <field.Errors class="w-full pt-1 text-right" as |errors|>
                <span class="label-text-alt block w-full text-xs text-orange-600 text-right">{{get (get errors 0) "message"}}</span>
              </field.Errors>
            </field.Label>

          </form.Field>

          <form.Field @name="phone" as |field|>
            <field.Label class="form-control flex flex-col items-start w-full max-w-md mb-4">
              <div class="label justify-start pb-1">
                <span class="label-text">Telefoon</span>
              </div>
              <field.Input @type="tel" class="input input-bordered w-full focus:outline-none focus:ring-2 focus:ring-[#ffe607] focus:border-[#ffe607]" />
              <field.Errors class="w-full pt-1 text-right" as |errors|>
                <span class="label-text-alt block w-full text-xs text-orange-600 text-right">{{get (get errors 0) "message"}}</span>
              </field.Errors>
            </field.Label>

          </form.Field>

          <form.Field @name="subject" as |field|>
            <field.Label class="form-control flex flex-col items-start w-full max-w-md mb-4">
              <div class="label justify-start pb-1">
                <span class="label-text">Onderwerp</span>
              </div>
              <field.Input class="input input-bordered w-full focus:outline-none focus:ring-2 focus:ring-[#ffe607] focus:border-[#ffe607]" />
              <field.Errors class="w-full pt-1 text-right" as |errors|>
                <span class="label-text-alt block w-full text-xs text-orange-600 text-right">{{get (get errors 0) "message"}}</span>
              </field.Errors>
            </field.Label>

          </form.Field>

          <form.Field @name="message" as |field|>
            <field.Label class="form-control flex flex-col items-start w-full max-w-md mb-4">
              <div class="label justify-start pb-1">
                <span class="label-text">Boodschap</span>
              </div>
              <field.Textarea class="textarea textarea-bordered w-full focus:outline-none focus:ring-2 focus:ring-[#ffe607] focus:border-[#ffe607]" rows="5" />

              <field.Errors class="w-full pt-1 text-right" as |errors|>
                <span class="label-text-alt block w-full text-xs text-orange-600 text-right">{{get (get errors 0) "message"}}</span>
              </field.Errors>
            </field.Label>
          </form.Field>

          <form.Field @name="reCaptchaToken" as |field|>
            <field.Label class="form-control flex flex-col items-start w-full max-w-md mb-4">
              <div class="label justify-start pb-1">
                <span class="label-text">Are you real?</span>
              </div>
              <GRecaptcha @onSuccess={{this.onCaptchaResolved}} @onExpired={{this.onCaptchaExpired}} @ref={{mut this.reCaptchaReference}} />

              <field.Errors class="w-full pt-1 text-right" as |errors|>
                <span class="label-text-alt block w-full text-xs text-orange-600 text-right">{{get (get errors 0) "message"}}</span>
              </field.Errors>
            </field.Label>
          </form.Field>

          <button type="submit" class="btn btn-primary w-100 mt-5">verzend</button>
        </HeadlessForm>

        {{#if this.isErrorneous}}
          <p>Er ging iets mis, probeer het nog een keer...</p>
        {{/if}}
      {{/unless}}

    </div>
  </div>

  <PortalTarget @name="section-contact" />

</div>