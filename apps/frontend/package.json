{
  "name": "@wonderkamer/frontend",
  "version": "1.6.3",
  "private": true,
  "description": "website voor Stichting Wonderkamer",
  "repository": "",
  "license": "UNLICENSED",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build-dev": "ember build --environment=testing",
    "build": "ember build --environment=production",
    "lint:css": "stylelint \"app/assets/**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint": "npm-run-all --aggregate-output --continue-on-error --parallel \"lint:!(fix)\"",
    "lint:fix": "npm-run-all --aggregate-output --continue-on-error --parallel lint:*:fix",
    "_lint:glint": "glint",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:prettier": "prettier . --list-different",
    "lint:prettier:fix": "prettier . --write",
    "preinstall": "npx only-allow pnpm",
    "release:major": "commit-and-tag-version --tag-prefix=\"\" --commit-all --release-as major",
    "release:minor": "commit-and-tag-version --tag-prefix=\"\" --commit-all --release-as minor",
    "release:patch": "commit-and-tag-version --tag-prefix=\"\" --commit-all --release-as patch",
    "release": "commit-and-tag-version --commit-all --tag-prefix=\"v\"",
    "start": "ember serve",
    "test:ember": "ember test",
    "test": "npm-run-all test:*"
  },
  "commit-and-tag-version": {
    "scripts": {}
  },
