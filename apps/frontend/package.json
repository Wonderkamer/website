{
  "name": "@wonderkamer/frontend",
  "version": "1.9.0",
  "private": true,
  "description": "website voor Stichting Wonderkamer",
  "repository": "",
  "license": "UNLICENSED",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "scripts": {
    "build-dev": "vite build --mode development",
    "build": "vite build",
    "typecheck": "glint",
    "lint:css": "stylelint \"app/assets/**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint": "npm-run-all --aggregate-output --continue-on-error --parallel \"lint:!(fix)\"",
    "lint:fix": "npm-run-all --aggregate-output --continue-on-error --parallel lint:*:fix",
    "_lint:glint": "glint",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:prettier": "prettier . --list-different",
    "lint:prettier:fix": "prettier . --write",
    "preinstall": "npx only-allow pnpm",
    "release:major": "commit-and-tag-version --tag-prefix=\"\" --commit-all --release-as major --infile ../../CHANGELOG.md",
    "release:minor": "commit-and-tag-version --tag-prefix=\"\" --commit-all --release-as minor --infile ../../CHANGELOG.md",
    "release:patch": "commit-and-tag-version --tag-prefix=\"\" --commit-all --release-as patch --infile ../../CHANGELOG.md",
    "release": "commit-and-tag-version --commit-all --tag-prefix=\"v\" --infile ../../CHANGELOG.md",
    "start": "vite dev",
    "test:ember": "vite build --mode test && ember test --path dist",
    "test": "npm-run-all test:*"
  },
  "commit-and-tag-version": {
    "scripts": {}
  },
  "dependencies": {
    "@wonderkamer/common": "workspace:*",
    "ember-element-helper": "0.8.7",
    "ember-headless-form": "1.1.1",
