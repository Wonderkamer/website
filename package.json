{
  "name": "@wonderkamer/website",
  "version": "1.6.0",
  "private": true,
  "description": "website voor Stichting Wonderkamer",
  "repository": "https://github.com/wonderkamer/website",
  "author": "bas@bushbaby.nl",
  "scripts": {
    "build": "turbo run build",
    "build:frontend": "turbo run build --filter=@wonderkamer/frontend",
    "build:backend": "turbo run build --filter=@wonderkamer/backend",
    "build:email-templates": "turbo run build --filter=@wonderkamer/email-templates",
    "lint:fix": "pnpm --filter '*' lint:fix",
    "lint": "turbo run lint",
    "preinstall": "npx only-allow pnpm",
    "release": "turbo run release",
    "start:dev": "concurrently --kill-others 'cd apps/frontend && pnpm run start' 'cd apps/backend && pnpm run start:debug'",
    "test": "turbo run test",
    "prepare": "husky || true",
    "knip": "knip"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.0",
    "@commitlint/config-conventional": "19.8.0",
    "@types/node": "22.14.1",
    "concurrently": "9.1.2",
    "dotenv": "16.5.0",
    "husky": "9.1.7",
    "knip": "5.50.4",
    "npm-run-all2": "7.0.2",
    "prettier": "latest",
    "rimraf": "6.0.1",
    "turbo": "2.5.0",
    "typescript": "5.8.3"
  },
  "resolutions": {
    "node-html-parser": "7.0.1"
  },
  "engines": {
    "node": ">= 20.*"
  },
  "packageManager": "pnpm@10.8.0"
}
