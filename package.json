{
  "name": "@wonderkamer/website",
  "version": "1.9.0",
  "private": true,
  "description": "website voor Stichting Wonderkamer",
  "repository": "https://github.com/wonderkamer/website",
  "author": "bas@bushbaby.nl",
  "scripts": {
    "build": "turbo run build",
    "build:frontend": "turbo run build --filter=@wonderkamer/frontend",
    "build:backend": "turbo run build --filter=@wonderkamer/backend",
    "build:email-templates": "turbo run build --filter=@wonderkamer/email-templates",
    "lint:fix": "pnpm --filter '*' lint:fix",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "preinstall": "npx only-allow pnpm",
    "release": "turbo run release",
    "start:dev": "concurrently --kill-others 'cd apps/frontend && pnpm run start' 'cd apps/backend && pnpm run start:debug'",
    "test": "turbo run test",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "22.14.1",
    "concurrently": "9.2.1",
    "husky": "9.1.7",
    "prettier": "3.8.4",
    "turbo": "2.9.16",
    "typescript": "5.5.4"
  },
  "resolutions": {
    "node-html-parser": "7.0.1"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
