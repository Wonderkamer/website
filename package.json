{
  "name": "@wonderkamer/website",
  "version": "1.6.0",
  "private": true,
  "description": "website voor Stichting Wonderkamer",
  "repository": "https://github.com/wonderkamer/website",
  "author": "bas@bushbaby.nl",
  "scripts": {
    "build": "turbo run build",
    "build:frontend": "turbo run build --filter=@wonderkamer/frontend",
    "build:backend": "turbo run build --filter=@wonderkamer/backend",
    "build:email-templates": "turbo run build --filter=@wonderkamer/email-templates",
    "lint:fix": "pnpm --filter '*' lint:fix",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "preinstall": "npx only-allow pnpm",
    "release": "turbo run release",
    "start:dev": "concurrently --kill-others 'cd apps/frontend && pnpm run start' 'cd apps/backend && pnpm run start:debug'",
    "test": "turbo run test",
    "prepare": "husky || true",
    "knip": "knip"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "22.14.1",
    "concurrently": "9.2.1",
    "dotenv": "16.6.1",
    "husky": "9.1.7",
    "knip": "5.50.4",
    "npm-run-all2": "7.0.2",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "turbo": "2.9.16",
    "typescript": "5.5.4"
  },
  "resolutions": {
    "node-html-parser": "7.0.1"
  },
  "engines": {
    "node": ">= 22.*"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
