{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "release": {
      "dependsOn": ["test"]
    },
    "build": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^test", "lint"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
